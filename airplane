<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>A380 Simulator - Custom Pro UI</title>
    <style>
        @font-face {
            font-family: 'Paperlogy';
            src: url('https://fastly.jsdelivr.net/gh/projectnoonnu/2405-3@1.1/Paperlogy-Medium.woff2') format('woff2');
            font-weight: 500;
        }

        body {
            background-color: #2c2e33; /* 이미지의 다크 그레이 배경 */
            color: #fff;
            font-family: 'Paperlogy', sans-serif;
            margin: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* 왼쪽 기록 패널 */
        #history-panel {
            width: 260px;
            background: #1e1f23;
            border-right: 1px solid #444;
            display: flex;
            flex-direction: column;
            padding: 20px;
        }
        #history-list { flex-grow: 1; overflow-y: auto; margin-top: 15px; }
        .history-item {
            background: #383c44; padding: 10px; border-radius: 6px;
            margin-bottom: 8px; font-size: 0.8rem; border-left: 3px solid #8eb0d9;
        }

        /* 메인 컨텐츠 */
        #main-container { flex-grow: 1; display: flex; flex-direction: column; position: relative; }

        /* 상단 옵션 조절 패널 (이미지 스타일) */
        #top-control-bar {
            background: #2c2e33;
            padding: 20px 0;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 30px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
            z-index: 10;
        }

        .control-item { display: flex; flex-direction: column; align-items: center; gap: 8px; }
        .control-item label { font-size: 0.75rem; color: #888; font-weight: 800; letter-spacing: 1px; }

        select {
            background: #3e424b; color: #fff; border: 1px solid #555;
            padding: 10px 15px; border-radius: 8px; font-family: 'Paperlogy';
            font-size: 0.9rem; cursor: pointer; min-width: 150px;
        }

        /* 속도 조절기 */
        .speed-ctrl { display: flex; align-items: center; gap: 10px; }
        .speed-btn {
            background: #545963; border: none; color: #fff; width: 32px; height: 32px;
            border-radius: 4px; cursor: pointer; font-size: 1.2rem; display: flex; align-items: center; justify-content: center;
        }
        #speed-val { font-size: 1.3rem; font-weight: 800; min-width: 60px; text-align: center; }
        .max-btn {
            background: #e3b04b; color: #000; padding: 6px 12px; border-radius: 4px;
            font-weight: 800; cursor: pointer; border: none; font-size: 0.8rem;
        }

        /* 동그란 액션 버튼 */
        .action-btns { display: flex; gap: 12px; margin-left: 10px; }
        .circle-btn {
            width: 65px; height: 65px; border-radius: 50%; border: none;
            font-family: 'Paperlogy'; font-weight: 900; cursor: pointer;
            transition: transform 0.2s, filter 0.2s; font-size: 1rem;
        }
        #start-btn { background: #fff; color: #000; }
        #stop-btn { background: #bc664f; color: #fff; }
        #reset-btn { background: #7a8288; color: #fff; }
        .circle-btn:hover { transform: scale(1.05); filter: brightness(1.1); }

        /* 대시보드 요약 (이미지 스타일) */
        #dashboard {
            background: #1e1f23;
            border: 1px solid #444;
            border-radius: 20px;
            padding: 25px 50px;
            display: flex;
            gap: 50px;
            margin: 30px auto;
            width: fit-content;
            align-items: center;
        }
        .dash-item { text-align: center; }
        .dash-label { font-size: 0.75rem; color: #888; font-weight: 800; display: block; margin-bottom: 5px; }
        .dash-val { font-size: 2rem; font-weight: 800; color: #8eb0d9; } /* 블루 톤 */
        .dash-val.yellow { color: #e3b04b; } /* 옐로우 톤 */

        /* 하단 범주 (이미지 스타일) */
        #legend-bar {
            background: #1e1f23;
            padding: 10px 25px;
            border-radius: 10px;
            display: flex;
            gap: 20px;
            margin: 0 auto 20px auto;
            font-size: 0.85rem;
            color: #ccc;
        }
        .leg-item { display: flex; align-items: center; gap: 8px; }
        .dot { width: 14px; height: 14px; border-radius: 50%; }
        .sq { border-radius: 3px; }

        /* 시뮬레이션 뷰포트 */
        #sim-viewport {
            flex-grow: 1; overflow-y: auto; padding: 20px;
            display: flex; flex-direction: column; align-items: center; gap: 40px;
        }
        canvas { background: #111; border-radius: 20px; border: 2px solid #444; }
    </style>
</head>
<body>

<div id="history-panel">
    <h3 style="margin-top:0; color:#8eb0d9; font-size:1.1rem;">BOARDING LOG</h3>
    <div id="history-list"><div style="color:#555; text-align:center;">No records yet.</div></div>
</div>

<div id="main-container">
    <div id="top-control-bar">
        <div class="control-item">
            <label>AIRCRAFT</label>
            <select id="model-select">
                <option value="A380">A380 (858석)</option>
                <option value="B787">B787 (306석)</option>
                <option value="A321">A321 (222석)</option>
            </select>
        </div>
        <div class="control-item">
            <label>METHOD</label>
            <select id="method-select">
                <option value="random">랜덤 입장</option>
                <option value="wilma">창가 우선 (Wilma)</option>
                <option value="zone">구역별 입장</option>
            </select>
        </div>
        <div class="control-item">
            <label>SPEED</label>
            <div class="speed-ctrl">
                <button class="speed-btn" onclick="changeSpeed(-1)">-</button>
                <span id="speed-val">1.0X</span>
                <button class="speed-btn" onclick="changeSpeed(1)">+</button>
                <button class="max-btn" onclick="setSpeed(50)">MAX</button>
            </div>
        </div>
        <div class="action-btns">
            <button id="start-btn" class="circle-btn">시작</button>
            <button id="stop-btn" class="circle-btn">중지</button>
            <button id="reset-btn" class="circle-btn">초기화</button>
        </div>
    </div>

    <div id="dashboard">
        <div class="dash-item"><span class="dash-label">TIME</span><span id="timer" class="dash-val">00:00</span></div>
        <div class="dash-item"><span class="dash-label">BOARDED</span><span id="count" class="dash-val">0 / 858</span></div>
        <div class="dash-item"><span class="dash-label">REMAIN</span><span id="remain" class="dash-val">858</span></div>
        <div style="width:1px; height:40px; background:#444; margin:0 10px;"></div>
        <div class="dash-item"><span class="dash-label">CURRENT ZONE</span><span id="zone-text" class="dash-val yellow">ALL</span></div>
    </div>

    <div id="legend-bar">
        <div class="leg-item"><span class="dot" style="background:#8eb0d9;"></span> 이동 중</div>
        <div class="leg-item"><span class="dot" style="background:#e3b04b;"></span> 짐칸 정리</div>
        <div class="leg-item"><span class="dot" style="background:#bc664f;"></span> 양보/대기 (병목)</div>
        <div class="leg-item"><span class="dot sq" style="background:#fff;"></span> 착석 완료</div>
        <div class="leg-item"><span class="dot sq" style="background:#333; border:1px solid #555;"></span> 빈 좌석</div>
    </div>

    <div id="sim-viewport">
        <div style="color:#888; font-size:0.8rem; margin-bottom:5px;">MAIN DECK (1F)</div>
        <canvas id="d1Canvas"></canvas>
        <div id="d2-label" style="color:#888; font-size:0.8rem; margin-bottom:5px;">UPPER DECK (2F)</div>
        <canvas id="d2Canvas"></canvas>
    </div>
</div>

<script>
    const d1Canvas = document.getElementById('d1Canvas');
    const d1Ctx = d1Canvas.getContext('2d');
    const d2Canvas = document.getElementById('d2Canvas');
    const d2Ctx = d2Canvas.getContext('2d');

    const MODELS = {
        'A380': { decks: [{ r: 53, l: [3, 'A', 4, 'A', 3] }, { r: 41, l: [2, 'A', 4, 'A', 2] }], total: 858 },
        'B787': { decks: [{ r: 34, l: [3, 'A', 3, 'A', 3] }], total: 306 },
        'A321': { decks: [{ r: 37, l: [3, 'A', 3] }], total: 222 }
    };

    let isRunning = false, totalTime = 0, lastTs = 0, simSpeed = 1;
    let paxList = [], waitQueue = [], config = MODELS['A380'], animationId = null;

    const S_SIZE = 14, M_X = 60, M_Y = 40;

    class Passenger {
        constructor(dIdx, r, c, x, y, aisleY, colMax) {
            this.deck = dIdx; this.tRow = r; this.tCol = c;
            this.tX = x; this.tY = y; this.aisleY = aisleY;
            this.curRow = -0.5; this.status = 'walk'; this.wait = 0;
            // Wilma Priority: 가장 바깥쪽(0 또는 colMax-1)이 0순위
            this.wilmaRank = Math.min(c, colMax - 1 - c);
        }
        update(occ, dt) {
            if (this.status === 'seated') return;
            if (this.wait > 0) { this.wait -= dt * simSpeed; return; }
            if (this.status === 'stow') {
                let block = false;
                paxList.forEach(p => {
                    if (p.status === 'seated' && p.deck === this.deck && p.tRow === this.tRow) {
                        if (Math.abs(this.tCol - this.aisleY) > Math.abs(p.tCol - this.aisleY)) block = true;
                    }
                });
                if (block) { this.status = 'shuf'; this.wait = 6; } else this.status = 'seated';
                return;
            }
            if (this.status === 'shuf') { this.status = 'seated'; return; }
            let nr = Math.floor(this.curRow + 1);
            if (nr < this.tRow) {
                if (!(occ[this.deck] && occ[this.deck][this.aisleY] && occ[this.deck][this.aisleY][nr])) {
                    this.curRow += dt * 6 * simSpeed;
                    if (this.curRow > nr) this.curRow = nr;
                }
            } else { this.status = 'stow'; this.wait = 10 + Math.random() * 10; }
        }
    }

    function changeSpeed(v) { setSpeed(simSpeed + v); }
    function setSpeed(v) {
        simSpeed = Math.max(0.5, Math.min(50, v));
        document.getElementById('speed-val').innerText = simSpeed.toFixed(1) + 'X';
    }

    function init() {
        const mKey = document.getElementById('model-select').value;
        config = MODELS[mKey];
        waitQueue = []; paxList = []; totalTime = 0; isRunning = false;
        if(animationId) cancelAnimationFrame(animationId);

        d2Canvas.style.display = config.decks.length > 1 ? 'block' : 'none';
        document.getElementById('d2-label').style.display = config.decks.length > 1 ? 'block' : 'none';

        config.decks.forEach((deck, dIdx) => {
            const canv = dIdx === 0 ? d1Canvas : d2Canvas;
            const colTotal = deck.l.reduce((a,b) => a + (b==='A'?1:b), 0);
            canv.width = (deck.r * S_SIZE) + (M_X * 2);
            canv.height = (colTotal * S_SIZE) + (M_Y * 2);
            let aisles = [], c = 0;
            deck.l.forEach(it => { if(it==='A'){aisles.push(c); c++;} else c+=it; });

            for (let r=0; r<deck.r; r++) {
                let cc = 0;
                deck.l.forEach(it => {
                    if(it==='A') cc++;
                    else {
                        for(let i=0; i<it; i++) {
                            let bA = aisles[0], minD = Math.abs(cc-aisles[0]);
                            aisles.forEach(ay => { if(Math.abs(cc-ay)<minD){minD=Math.abs(cc-ay); bA=ay;} });
                            waitQueue.push(new Passenger(dIdx, r+1, cc, M_X+r*S_SIZE, M_Y+cc*S_SIZE, bA, colTotal));
                            cc++;
                        }
                    }
                });
            }
        });

        const method = document.getElementById('method-select').value;
        if (method === 'wilma') waitQueue.sort((a,b) => a.wilmaRank - b.wilmaRank || a.tRow - b.tRow);
        else if (method === 'zone') waitQueue.sort((a,b) => b.tRow - a.tRow + (Math.random()-0.5)*5);
        else waitQueue.sort(() => Math.random() - 0.5);

        draw(); updateStats();
    }

    function draw() {
        [d1Ctx, d2Ctx].forEach((ctx, dIdx) => {
            if (dIdx >= config.decks.length) return;
            const deck = config.decks[dIdx];
            ctx.clearRect(0,0,ctx.canvas.width, ctx.canvas.height);
            ctx.fillStyle = '#1e1e1e';
            ctx.fillRect(M_X-10, M_Y-5, (deck.r*S_SIZE)+20, ctx.canvas.height-(M_Y*2)+10);
            
            paxList.concat(waitQueue).filter(p => p.deck === dIdx).forEach(p => {
                ctx.fillStyle = '#333';
                ctx.fillRect(p.tX+1, p.tY+1, S_SIZE-2, S_SIZE-2);
            });

            paxList.filter(p => p.deck === dIdx).forEach(p => {
                if (p.status === 'seated') { ctx.fillStyle = '#fff'; ctx.fillRect(p.tX+1, p.tY+1, S_SIZE-2, S_SIZE-2); }
                else if (p.curRow >= 0) {
                    if(p.status === 'shuf') ctx.fillStyle = '#bc664f';
                    else if(p.status === 'stow') ctx.fillStyle = '#e3b04b';
                    else ctx.fillStyle = '#8eb0d9';
                    ctx.beginPath(); ctx.arc(M_X+p.curRow*S_SIZE+S_SIZE/2, M_Y+p.aisleY*S_SIZE+S_SIZE/2, S_SIZE/2.5, 0, Math.PI*2); ctx.fill();
                }
            });
        });
    }

    function loop(ts) {
        if (!isRunning) return;
        const dt = (ts - (lastTs || ts)) / 1000;
        lastTs = ts; totalTime += dt * simSpeed;

        let occ = [{}, {}];
        paxList.forEach(p => {
            if (p.status !== 'seated' && p.curRow >= 0) {
                if(!occ[p.deck]) occ[p.deck] = {};
                if(!occ[p.deck][p.aisleY]) occ[p.deck][p.aisleY] = {};
                occ[p.deck][p.aisleY][Math.floor(p.curRow + 0.7)] = true;
            }
        });

        if (waitQueue.length > 0 && Math.random() < 0.7 * simSpeed) {
            let p = waitQueue[0];
            if (!(occ[p.deck] && occ[p.deck][p.aisleY] && occ[p.deck][p.aisleY][0])) {
                p = waitQueue.shift(); p.curRow = 0; paxList.push(p);
            }
        }
        paxList.forEach(p => p.update(occ, dt));
        draw(); updateStats();

        if (paxList.filter(p => p.status === 'seated').length === config.total) {
            isRunning = false; addHistory();
        } else { animationId = requestAnimationFrame(loop); }
    }

    function updateStats() {
        document.getElementById('timer').innerText = formatTime(totalTime);
        const seated = paxList.filter(p => p.status === 'seated').length;
        document.getElementById('count').innerText = `${seated} / ${config.total}`;
        document.getElementById('remain').innerText = config.total - seated;
        const method = document.getElementById('method-select').value;
        document.getElementById('zone-text').innerText = method === 'zone' ? (waitQueue.length > 0 ? `Z${Math.ceil(waitQueue[0].tRow/10)}` : 'DONE') : 'ALL';
    }

    function addHistory() {
        const list = document.getElementById('history-list');
        if (list.innerHTML.includes('No records')) list.innerHTML = '';
        const div = document.createElement('div');
        div.className = 'history-item';
        const method = document.getElementById('method-select').options[document.getElementById('method-select').selectedIndex].text;
        div.innerHTML = `<strong>${method}</strong><br>Time: ${formatTime(totalTime)} / ${config.total}석`;
        list.prepend(div);
    }

    function formatTime(s) {
        const m = Math.floor(s/60); const sec = Math.floor(s%60);
        return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
    }

    document.getElementById('start-btn').onclick = () => {
        if (isRunning) return;
        if (paxList.length === 0 || paxList.filter(p => p.status === 'seated').length === config.total) init();
        isRunning = true; lastTs = 0; animationId = requestAnimationFrame(loop);
    };
    document.getElementById('stop-btn').onclick = () => { isRunning = false; };
    document.getElementById('reset-btn').onclick = init;
    document.getElementById('model-select').onchange = init;
    document.getElementById('method-select').onchange = init;

    init();
</script>
</body>
</html>
